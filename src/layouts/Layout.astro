---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	lang?: string; // Dodajemy opcjonalny parametr języka
}

// Domyślnie ustawiamy język polski ('pl')
const { title, lang = 'pl' } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | EMPAT Solutions</title>
	</head>
	<body class="bg-slate-900 text-slate-100 font-sans antialiased selection:bg-cyan-500 selection:text-slate-900 m-0 p-0">
		<Header lang={lang} />
		<main>
			<slot />
		</main>
	</body>
</html>
