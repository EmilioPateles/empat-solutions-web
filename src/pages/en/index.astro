            <Image src="/logo-9.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-10.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-11.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-12.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-13.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
          </div>

        </div>
      </div>
    </section>

    <section class="py-16 bg-slate-900/30 border-b border-slate-800 relative z-10 overflow-hidden">
      <div class="max-w-4xl mx-auto px-4 text-center animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">
        <h2 class="text-sm font-bold tracking-widest text-cyan-500 uppercase mb-8">Trusted By</h2>
        <div id="testimonial-wrapper" class="relative min-h-[200px] flex items-center justify-center">
          <div class="testimonial-slide absolute inset-0 transition-all duration-1000 ease-in-out opacity-100 translate-x-0 flex flex-col justify-center items-center">
            <p class="text-2xl font-medium text-slate-200 italic mb-6 max-w-3xl">"The training opened my eyes and helped me understand the possibilities that artificial intelligence offers."</p>
            <div>
              <div class="text-white font-bold text-lg">Wiktoria Papała</div>
              <div class="text-cyan-400">Owner, Papaja Tattoo</div>
            </div>
          </div>
          <div class="testimonial-slide absolute inset-0 transition-all duration-1000 ease-in-out opacity-0 translate-x-8 pointer-events-none flex flex-col justify-center items-center">
            <p class="text-2xl font-medium text-slate-200 italic mb-6 max-w-3xl">"Thanks to Emil, I found the perfect partner."</p>
            <div>
              <div class="text-white font-bold text-lg">Iza Dudzik</div>
              <div class="text-cyan-400">Intern, Papaja Tattoo / Illustrator</div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <section id="about" class="py-24 bg-slate-800/30 border-t border-slate-800 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">
      
<div class="relative w-full max-w-md mx-auto aspect-square md:aspect-[4/5] rounded-2xl overflow-hidden border border-slate-700 shadow-2xl group">
  
  <div class="absolute inset-0 bg-slate-900/40 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"></div>
  
  <Image 
    src={emilImg} 
    alt="dr inż. Emil Patelski" 
    class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 scale-100 group-hover:scale-105 transition-all duration-700"
  />
  
  <div class="absolute bottom-0 left-0 w-full h-1.5 bg-cyan-500 z-20 shadow-[0_0_15px_rgba(6,182,212,0.5)]"></div>
</div>
        <div>
          <h2 class="text-sm font-bold tracking-widest text-cyan-500 uppercase mb-3">About the Founder</h2>
          <h3 class="text-4xl font-bold text-white mb-6">Practice, Concrete Solutions, Measurable Results.</h3>
          <p class="text-slate-400 text-lg leading-relaxed mb-6">
            My name is Dr. Eng. Emil Patelski. I don't complicate things. I create solutions that take over tedious processes in your company. My philosophy is simple: You are the driver, we provide the engine. We take the technology off your shoulders so you can focus on maximizing profits.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="projects" class="py-24 bg-slate-900 border-t border-slate-800 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">
        <h2 class="text-sm font-bold tracking-widest text-cyan-500 uppercase mb-3">Case Studies</h2>
        <h3 class="text-4xl font-bold text-white">Concrete solutions to problems</h3>
      </div>
      
      <div class="bg-slate-800/40 border border-slate-700 rounded-2xl overflow-hidden shadow-2xl transition-all hover:border-cyan-500/50 animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out delay-100">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
          <div class="p-8 lg:p-12 border-b lg:border-b-0 lg:border-r border-slate-700">
            <h4 class="text-3xl font-bold text-white mb-4">AI in Creative Marketing</h4>
            
            <div class="flex items-center gap-4 mb-6">
              <h5 class="text-xl text-slate-300 font-medium m-0">Client: <span class="text-white">Papaja Tattoo</span></h5>
              <div class="h-16 w-px bg-slate-700"></div>
              <img src="/papaja-logo.png" alt="Papaja Tattoo Logo" loading="lazy" class="h-32 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" />
            </div>

            <p class="text-slate-400 mb-8 leading-relaxed">
              As part of our collaboration, we demonstrated how AI-powered tools can support marketing activities and drastically increase social media reach.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start text-slate-300">
                <svg class="w-6 h-6 shrink-0 text-cyan-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Creating video scripts for TikTok and Reels.
              </li>
              <li class="flex items-start text-slate-300">
                <svg class="w-6 h-6 shrink-0 text-cyan-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                Intelligent video and audio post-production.
              </li>
            </ul>
          </div>
          <div class="p-8 lg:p-12 bg-slate-800/80 flex flex-col justify-center">
            <h4 class="text-xl font-bold text-white mb-4">Operational Impact</h4>
            <p class="text-slate-400 leading-relaxed">
              We optimized the time required to produce promotional materials, directly translating into increased reach and much deeper client interaction.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="py-24 bg-slate-800/30 border-t border-slate-800 scroll-mt-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm font-bold tracking-widest text-cyan-500 uppercase mb-3 text-center animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">Have questions?</h2>
      <h3 class="text-4xl font-bold text-white mb-12 text-center animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">Frequently Asked Questions</h3>
      
      <div class="space-y-6">
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/30 transition-colors animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">
          <h4 class="text-xl font-bold text-white mb-3">Is my company ready for AI?</h4>
          <p class="text-slate-400">Yes. You don't need advanced IT infrastructure. We start with simple tools that immediately deliver a return on investment (ROI).</p>
        </div>
        <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 hover:border-cyan-500/30 transition-colors animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out delay-100">
          <h4 class="text-xl font-bold text-white mb-3">How long does implementation take?</h4>
          <p class="text-slate-400">Basic automations can be implemented in a few days. Building a comprehensive customized "Digital Employee" usually takes 2-4 weeks.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="py-24 bg-slate-900 border-t border-slate-800 scroll-mt-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll opacity-0 translate-y-12 transition-all duration-700 ease-out">
      <h2 class="text-sm font-bold tracking-widest text-cyan-500 uppercase mb-3">Let's Get Started</h2>
      <h3 class="text-4xl font-bold text-white mb-12">Contact Us</h3>

<form id="contact-form" class="bg-slate-800/50 border border-slate-700 rounded-2xl p-8 mb-16 text-left max-w-2xl mx-auto">
        
        <input type="hidden" name="access_key" value="bb8fa602-ed0d-4c8f-a8a9-bbabcd828ce8">
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

        <div class="space-y-6">
          <div>
            <label for="en-name" class="block text-sm font-medium text-slate-300 mb-2">Full Name</label>
            <input type="text" id="en-name" name="name" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500" placeholder="John Doe">
          </div>
          <div>
            <label for="en-email" class="block text-sm font-medium text-slate-300 mb-2">Email Address</label>
            <input type="email" id="en-email" name="email" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500" placeholder="john@company.com">
          </div>
          <div>
            <label for="en-message" class="block text-sm font-medium text-slate-300 mb-2">Message</label>
            <textarea id="en-message" name="message" rows="4" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-cyan-500" placeholder="How can we help you?"></textarea>
          </div>
          
          <button type="submit" id="submit-btn" class="w-full bg-cyan-500 hover:bg-cyan-400 text-slate-900 font-bold py-4 rounded-lg transition-colors flex justify-center items-center">
            <span>Send Message</span>
          </button>

          <p id="form-result" class="text-center text-sm font-bold hidden mt-4"></p>
        </div>
      </form>

      <div class="pt-12 border-t border-slate-800">
        <h4 class="text-2xl font-bold text-white mb-4">Prefer faster contact?</h4>
        <p class="text-slate-400 mb-8">Message me directly on WhatsApp. I respond faster than any form.</p>
        <a href="https://wa.me/+48512105610?text=Hi%20Emil,%20I'd%20like%20to%20talk%20about%20automation." 
           target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#1EBE55] text-white px-8 py-4 rounded-xl font-bold text-lg transition-all shadow-[0_0_15px_rgba(37,211,102,0.3)] hover:shadow-[0_0_25px_rgba(37,211,102,0.6)]">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 3.825 0 6.938 3.112 6.938 6.937 0 3.825-3.113 6.938-6.938 6.938z"/></svg>
          Message me on WhatsApp
        </a>
      </div>
    </div>
  </section>

  <style>
    .animate-marquee {
      animation: marquee 60s linear infinite;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Inicjalizacja Animacji Scrolla
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('opacity-0', 'translate-y-12');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });

      // Animacja Hero Section
      setTimeout(() => {
        const hero = document.querySelector('.animate-on-load');
        if (hero) {
          hero.classList.remove('opacity-0', 'translate-y-8');
          hero.classList.add('opacity-100', 'translate-y-0');
        }
      }, 100);

      // 2. Rotator (Opinie)
      const slides = document.querySelectorAll('.testimonial-slide');
      let currentIdx = 0;
      if(slides.length > 1) {
        setInterval(() => {
          slides[currentIdx].classList.remove('opacity-100', 'translate-x-0');
          slides[currentIdx].classList.add('opacity-0', '-translate-x-8', 'pointer-events-none');
          currentIdx = (currentIdx + 1) % slides.length;
          slides[currentIdx].classList.remove('-translate-x-8');
          slides[currentIdx].classList.add('translate-x-8');
          setTimeout(() => {
            slides[currentIdx].classList.remove('opacity-0', 'translate-x-8', 'pointer-events-none');
            slides[currentIdx].classList.add('opacity-100', 'translate-x-0');
          }, 50);
        }, 6000); 
      }

      // 3. Web3Forms - Obsługa formularza kontaktowego (Wersja EN)
      const form = document.getElementById('contact-form');
      const result = document.getElementById('form-result');
      const submitBtn = document.getElementById('submit-btn');
      
      if(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault(); 
          
          const btnText = submitBtn ? submitBtn.querySelector('span') : null;
          const formData = new FormData(form);
          const object = Object.fromEntries(formData);
          const json = JSON.stringify(object);

          // Stan ładowania - UI
          result.classList.remove('hidden', 'text-red-500', 'text-green-500');
          result.classList.add('text-cyan-400');
          result.innerHTML = "Sending...";
          if(btnText) btnText.innerHTML = "Processing...";
          submitBtn.disabled = true;
          submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

          // Strzał do API
          fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json',
                  'Accept': 'application/json'
              },
              body: json
          })
          .then(async (response) => {
              let json = await response.json();
              if (response.status == 200) {
                  // Sukces
                  result.classList.remove('text-cyan-400', 'text-red-500');
                  result.classList.add('text-green-500');
                  result.innerHTML = "Message sent! We will get back to you soon.";
                  if(btnText) btnText.innerHTML = "Sent successfully";
                  form.reset(); 
              } else {
                  // Błąd z serwera
                  console.log(response);
                  result.classList.remove('text-cyan-400', 'text-green-500');
                  result.classList.add('text-red-500');
                  result.innerHTML = json.message || "Something went wrong. Please try again.";
                  if(btnText) btnText.innerHTML = "Send Message";
                  submitBtn.disabled = false;
                  submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
              }
          })
          .catch(error => {
              // Błąd sieci/internetu
              console.log(error);
              result.classList.remove('text-cyan-400', 'text-green-500');
              result.classList.add('text-red-500');
              result.innerHTML = "Connection error. Please check your internet and try again.";
              if(btnText) btnText.innerHTML = "Send Message";
              submitBtn.disabled = false;
              submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
          })
          .then(function() {
              // Ukryj komunikat po 6 sekundach
              setTimeout(() => {
                  result.classList.add('hidden');
                  if(!submitBtn.disabled && btnText) {
                     btnText.innerHTML = "Send Message";
                  }
              }, 6000);
          });
        });
      }
    });
  </script>

</Layout>
