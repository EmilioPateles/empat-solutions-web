---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import emilImg from '../../assets/emil.jpg';
---

<Layout 
  lang="en"
  title="We Implement AI & Automation"
  description="We take over tedious processes in your company. We design custom Artificial Intelligence systems so you can reclaim 10 hours a week and focus on profits."
>
  
  <div id="home">
    <section class="min-h-[90vh] flex flex-col bg-gradient-to-b from-slate-900 via-slate-900 to-slate-800 pt-32 pb-8">
      
      <div class="flex-grow flex flex-col justify-center items-center w-full px-4 pb-12 text-center">
        <div class="max-w-4xl mx-auto animate-on-load opacity-0 translate-y-8 transition-all duration-1000 ease-out">
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-6">
            Growth driven by <br /><span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Artificial Intelligence</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-300 mb-10">
            We optimize processes, increase productivity, and implement secure AI solutions for your company. Boost operational efficiency, and spend the saved time relaxing at a SPA or taking a quick trip to the seaside.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#contact" class="bg-cyan-500 hover:bg-cyan-400 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg transition-all shadow-[0_0_20px_rgba(6,182,212,0.4)] hover:shadow-[0_0_30px_rgba(6,182,212,0.7)]">
              Free Consultation
            </a>
            <a href="#projects" class="bg-slate-800 hover:bg-slate-700 text-white px-8 py-4 rounded-lg font-bold text-lg transition-colors border border-slate-700">
              See Case Studies
            </a>
          </div>
        </div>
      </div>

      <div class="w-full border-y border-slate-700 bg-slate-900/50 py-6 overflow-hidden logo-carousel-container">
        <div class="flex flex-nowrap w-max animate-marquee hover:[animation-play-state:paused]">
          
          <div class="flex flex-nowrap items-center gap-16 px-8 shrink-0">
            <Image src="/logo-1.png" alt="Technology 1" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-2.png" alt="Technology 2" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-3.png" alt="Technology 3" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-4.png" alt="Technology 4" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-5.png" alt="Technology 5" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-6.png" alt="Technology 6" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-7.png" alt="Technology 7" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-8.png" alt="Technology 8" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-9.png" alt="Technology 9" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-10.png" alt="Technology 10" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-11.png" alt="Technology 11" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-12.png" alt="Technology 12" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-13.png" alt="Technology 13" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
          </div>

          <div class="flex flex-nowrap items-center gap-16 px-8 shrink-0" aria-hidden="true">
            <Image src="/logo-1.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-2.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-3.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-4.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-5.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-6.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
            <Image src="/logo-7.png" alt="" width={120} height={40} loading="eager" fetchpriority="high" class="shrink-0 h-10 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 cursor-pointer" />
