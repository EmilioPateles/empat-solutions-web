<script>
    document.addEventListener('DOMContentLoaded', () => {
      // 1. Inicjalizacja Animacji Scrolla
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('opacity-0', 'translate-y-12');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });

      // Animacja Hero Section
      setTimeout(() => {
        const hero = document.querySelector('.animate-on-load');
        if (hero) {
          hero.classList.remove('opacity-0', 'translate-y-8');
          hero.classList.add('opacity-100', 'translate-y-0');
        }
      }, 100);

      // 2. Rotator (Opinie)
      const slides = document.querySelectorAll('.testimonial-slide');
      let currentIdx = 0;
      if(slides.length > 1) {
        setInterval(() => {
          slides[currentIdx].classList.remove('opacity-100', 'translate-x-0');
          slides[currentIdx].classList.add('opacity-0', '-translate-x-8', 'pointer-events-none');
          currentIdx = (currentIdx + 1) % slides.length;
          slides[currentIdx].classList.remove('-translate-x-8');
          slides[currentIdx].classList.add('translate-x-8');
          setTimeout(() => {
            slides[currentIdx].classList.remove('opacity-0', 'translate-x-8', 'pointer-events-none');
            slides[currentIdx].classList.add('opacity-100', 'translate-x-0');
          }, 50);
        }, 6000); 
      }

      // 3. Web3Forms - Obsługa formularza kontaktowego
      const form = document.getElementById('contact-form');
      const result = document.getElementById('form-result');
      const submitBtn = document.getElementById('submit-btn');
      
      if(form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault(); // Blokujemy domyślne przeładowanie strony
          
          const btnText = submitBtn ? submitBtn.querySelector('span') : null;
          const formData = new FormData(form);
          const object = Object.fromEntries(formData);
          const json = JSON.stringify(object);

          // Stan ładowania - UI
          result.classList.remove('hidden', 'text-red-500', 'text-green-500');
          result.classList.add('text-cyan-400');
          result.innerHTML = "Trwa wysyłanie...";
          if(btnText) btnText.innerHTML = "Przetwarzanie...";
          submitBtn.disabled = true;
          submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

          // Strzał do API
          fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json',
                  'Accept': 'application/json'
              },
              body: json
          })
          .then(async (response) => {
              let json = await response.json();
              if (response.status == 200) {
                  // Sukces
                  result.classList.remove('text-cyan-400', 'text-red-500');
                  result.classList.add('text-green-500');
                  result.innerHTML = "Wiadomość wysłana! Odezwiemy się wkrótce.";
                  if(btnText) btnText.innerHTML = "Wysłano pomyślnie";
                  form.reset(); // Czyszczenie pól po wysłaniu
              } else {
                  // Błąd z serwera
                  console.log(response);
                  result.classList.remove('text-cyan-400', 'text-green-500');
                  result.classList.add('text-red-500');
                  result.innerHTML = json.message || "Coś poszło nie tak. Spróbuj ponownie.";
                  if(btnText) btnText.innerHTML = "Wyślij wiadomość";
                  submitBtn.disabled = false;
                  submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
              }
          })
          .catch(error => {
              // Błąd sieci/internetu
              console.log(error);
              result.classList.remove('text-cyan-400', 'text-green-500');
              result.classList.add('text-red-500');
              result.innerHTML = "Błąd połączenia. Sprawdź internet i spróbuj ponownie.";
              if(btnText) btnText.innerHTML = "Wyślij wiadomość";
              submitBtn.disabled = false;
              submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
          })
          .then(function() {
              // Ukryj komunikat po 6 sekundach
              setTimeout(() => {
                  result.classList.add('hidden');
                  if(!submitBtn.disabled && btnText) {
                     btnText.innerHTML = "Wyślij wiadomość";
                  }
              }, 6000);
          });
        });
      }
    });
  </script>

